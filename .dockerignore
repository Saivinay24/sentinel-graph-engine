# ── Virtual environments ───────────────────────────────────────────────────
venv/
.venv/
env/

# ── Python bytecode & caches ───────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Secrets & environment files ───────────────────────────────────────────
.env
.env.*
*.key
*.pem
secrets/

# ── Version control ────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Large serialised model/data files (loaded via mounted volumes) ─────────
data/generated/*.pkl
data/generated/*.joblib
models/*.pt
models/*.pth
models/*.pkl

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS artefacts ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Docs (not needed in image) ────────────────────────────────────────────
docs/
*.md
